{
  "expo": {
    "name": "AmyChat",
    "slug": "talky",
    "scheme": "amychat",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2E9E83"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "O AmyChat precisa da sua galeria para você anexar fotos no chat."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "O AmyChat precisa do microfone para você gravar áudios no chat."
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.yohancayres.amychat",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "c676b57b-8df6-4197-a277-2e7adeaf4517"
      }
    }
  }
}
