# Variáveis do docker-compose.yml (produção). Copie para .env na raiz.
# As chaves de IA e config do app ficam em backend/.env.

# Credenciais do MongoDB (use uma senha forte).
MONGO_USER=talky
MONGO_PASSWORD=troque-por-uma-senha-forte
MONGO_DB=talky

# Porta exposta do backend no host (atrás do seu proxy/HTTPS).
BACKEND_PORT=3000

# Imagem publicada pelo CI (GHCR). Em build local, pode deixar em branco.
# BACKEND_IMAGE=ghcr.io/seu_usuario/talky-backend:latest
