# Copie este arquivo para .env e preencha com a sua chave.
# Obtenha uma chave em https://console.anthropic.com/

ANTHROPIC_API_KEY=

# Modelo usado para gerar personagens e responder no chat.
# Padrão: claude-opus-4-7. Para respostas mais rápidas/baratas, use claude-sonnet-4-6.
TALKY_MODEL=claude-opus-4-7

# Porta do servidor HTTP.
PORT=3000

# --- Foto de perfil (gerada por IA de imagem da OpenAI) ---
# Opcional: sem esta chave, o personagem usa o avatar de emoji.
OPENAI_API_KEY=
IMAGE_GEN_ENABLED=true
TALKY_IMAGE_MODEL=gpt-image-2
TALKY_IMAGE_SIZE=1024x1024
# Endpoint da API de imagens (mude se usar outro provedor compatível).
OPENAI_IMAGE_ENDPOINT=https://api.openai.com/v1/images/generations

# --- Mensagens proativas (o personagem manda mensagem sozinho) ---
# Liga/desliga o recurso.
PROACTIVE_ENABLED=true
# Intervalo de silêncio (em minutos) antes de uma mensagem espontânea.
# Para DEMONSTRAR rápido, troque por 1 e 2.
PROACTIVE_MIN_GAP_MINUTES=120
PROACTIVE_MAX_GAP_MINUTES=360
# "Horário de sono" do personagem (não manda mensagem nesse intervalo, 0-23).
PROACTIVE_QUIET_START=23
PROACTIVE_QUIET_END=7
# De quanto em quanto tempo o agendador verifica (segundos).
PROACTIVE_CHECK_INTERVAL_SECONDS=30
# Máximo de mensagens seguidas do personagem sem resposta do usuário.
PROACTIVE_MAX_CONSECUTIVE=3

# --- Busca na web (notícias e cotidiano real) ---
# O personagem usa busca na web para comentar notícias/cotidiano de verdade.
WEB_SEARCH_ENABLED=true
# Quantas buscas o modelo pode fazer por mensagem.
WEB_SEARCH_MAX_USES=3
# Chance (0-1) de uma mensagem proativa ser baseada em notícias do dia.
PROACTIVE_NEWS_CHANCE=0.4
# Permite busca também nas respostas normais (mais lento). Padrão: false.
WEB_SEARCH_IN_REPLIES=false

# --- Respostas com atraso humano (não responde na hora) ---
# Se false, o personagem responde imediatamente (comportamento antigo).
REPLY_DELAY_ENABLED=true
# Multiplica TODOS os atrasos. Para testar rápido, use algo como 0.05.
REPLY_SPEED_FACTOR=1
# De quanto em quanto tempo o servidor verifica respostas pendentes (segundos).
REPLY_CHECK_INTERVAL_SECONDS=3
# Janela (segundos) antes da entrega em que o app mostra "digitando...".
REPLY_TYPING_WINDOW_SECONDS=12
# Teto do atraso quando o personagem está acordado (minutos).
REPLY_MAX_AWAKE_MINUTES=30

# --- Personagens globais ---
# Chance (0-1) de um novo usuário ser conectado a um personagem que JÁ existe
# no pool global, em vez de criar um novo. 0 = sempre cria; 1 = sempre reusa.
CHARACTER_POOL_REUSE_CHANCE=0.5
