# Copie este arquivo para .env e preencha com a sua chave.
# Obtenha uma chave em https://console.anthropic.com/

ANTHROPIC_API_KEY=

# Modelo usado para gerar personagens e responder no chat.
# Padrão: claude-opus-4-7. Para respostas mais rápidas/baratas, use claude-sonnet-4-6.
TALKY_MODEL=claude-opus-4-7

# Porta do servidor HTTP.
PORT=3000

# Persistência (produção): URI do MongoDB. Sem ela, usa o arquivo db.json (dev).
# No docker-compose, isto é definido automaticamente apontando para o serviço "mongo".
# MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=talky

# --- Foto de perfil (gerada por IA de imagem da OpenAI) ---
# Opcional: sem esta chave, o personagem usa o avatar de emoji.
OPENAI_API_KEY=
IMAGE_GEN_ENABLED=true
TALKY_IMAGE_MODEL=gpt-image-2
TALKY_IMAGE_SIZE=1024x1024
# Endpoint da API de imagens (mude se usar outro provedor compatível).
OPENAI_IMAGE_ENDPOINT=https://api.openai.com/v1/images/generations
# Tempo máximo de espera pela imagem (segundos) antes de desistir com erro.
IMAGE_TIMEOUT_SECONDS=90

# --- Mensagens proativas (o personagem manda mensagem sozinho) ---
# Liga/desliga o recurso.
PROACTIVE_ENABLED=true
# Intervalo de silêncio (em minutos) antes de uma mensagem espontânea.
# Para DEMONSTRAR rápido, troque por 1 e 2.
PROACTIVE_MIN_GAP_MINUTES=120
PROACTIVE_MAX_GAP_MINUTES=360
# "Horário de sono" do personagem (não manda mensagem nesse intervalo, 0-23).
PROACTIVE_QUIET_START=23
PROACTIVE_QUIET_END=7
# De quanto em quanto tempo o agendador verifica (segundos).
PROACTIVE_CHECK_INTERVAL_SECONDS=30
# Máximo de mensagens seguidas do personagem sem resposta do usuário.
PROACTIVE_MAX_CONSECUTIVE=3

# --- Busca na web (notícias e cotidiano real) ---
# O personagem usa busca na web para comentar notícias/cotidiano de verdade.
WEB_SEARCH_ENABLED=true
# Quantas buscas o modelo pode fazer por mensagem.
WEB_SEARCH_MAX_USES=3
# Chance (0-1) de uma mensagem proativa ser baseada em notícias do dia.
PROACTIVE_NEWS_CHANCE=0.4
# Permite busca também nas respostas normais (mais lento). Padrão: false.
WEB_SEARCH_IN_REPLIES=false

# --- Respostas com atraso humano (não responde na hora) ---
# Se false, o personagem responde imediatamente (comportamento antigo).
REPLY_DELAY_ENABLED=true
# Multiplica TODOS os atrasos. Para testar rápido, use algo como 0.05.
REPLY_SPEED_FACTOR=1
# De quanto em quanto tempo o servidor verifica respostas pendentes (segundos).
REPLY_CHECK_INTERVAL_SECONDS=3
# Janela (segundos) antes da entrega em que o app mostra "digitando...".
REPLY_TYPING_WINDOW_SECONDS=12
# Teto do atraso quando o personagem está acordado (minutos).
REPLY_MAX_AWAKE_MINUTES=30
# Quantas mensagens recentes enviar ao modelo por turno (controla o custo em
# conversas grandes). Menor = mais barato, porém menos memória de longo prazo.
REPLY_HISTORY_LIMIT=30

# --- Áudio ---
# Transcrição dos áudios que o usuário envia (Whisper/OpenAI).
OPENAI_TRANSCRIBE_MODEL=whisper-1
# O personagem responde em áudio (TTS) quando o usuário PEDE. false desliga.
TTS_ENABLED=true
# Provedor de voz: 'elevenlabs' (melhor pt-BR) ou 'openai'. Se ELEVENLABS_API_KEY
# estiver setada, o padrão já é elevenlabs.
# TTS_PROVIDER=elevenlabs
# ElevenLabs (recomendado): cada personagem recebe uma voz da sua conta.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
# Voz de fallback (id) se a busca de vozes da conta falhar (opcional).
ELEVENLABS_VOICE=
# OpenAI TTS (fallback): gpt-4o-mini-tts aceita "instructions" de personalidade.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
# Pitch-shift real (afina/engrossa a voz por personagem) via ffmpeg. Requer
# ffmpeg instalado (o Docker já inclui). Sem ele, usa o áudio original.
TTS_PITCH_SHIFT=true
# Ambiente do áudio: 'room' (quarto), 'office' (escritório) ou 'off' para desligar.
TTS_AMBIENCE=room
# Hesitações/pausas naturais no áudio ("hmm...", "é...", "ahh,") em pontos certos.
TTS_FILLERS=true

# --- Personagens globais ---
# Chance (0-1) de um novo usuário ser conectado a um personagem que JÁ existe
# no pool global, em vez de criar um novo. 0 = sempre cria; 1 = sempre reusa.
CHARACTER_POOL_REUSE_CHANCE=0.5

# --- Humor da persona ---
# O personagem tem um humor que muda dia a dia (mais animado, triste, cansado,
# entediado...), com viés do temperamento. Entra no tom das conversas.
MOOD_ENABLED=true
# Além da variação diária, as conversas deslocam o humor (papo bom anima, papo
# pesado deixa pra baixo, etc.). Usa uma chamada leve extra por resposta.
MOOD_CONVERSATION_EFFECT=true
# A avaliação de humor/intimidade roda a cada N mensagens (não a cada uma),
# para economizar chamadas ao modelo.
IMPACT_ASSESS_EVERY=10

# --- Intimidade (controle interno por conversa) ---
# Cada conversa tem uma intimidade (0-100, NUNCA exibida) que molda o quanto o
# personagem se abre. Cresce devagar com bom convívio (cada personagem tem uma
# taxa de ganho própria) e CAI quando o usuário força intimidade cedo demais.
INTIMACY_ENABLED=true

# --- Ritmo de digitação / picotar mensagens ---
# As respostas levam um tempo de "digitação" proporcional ao tamanho, e cada
# personagem picota (ou agrupa) as mensagens conforme seu estilo. Este fator
# multiplica a duração da digitação (use < 1 para testar mais rápido).
REPLY_TYPING_SPEED_FACTOR=1
